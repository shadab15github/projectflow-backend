            "url": { "raw": "{{baseUrl}}/sprints/{{sprintId}}/close", "host": ["{{baseUrl}}"], "path": ["sprints", "{{sprintId}}", "close"] }
          }
        },
        {
          "name": "Delete sprint",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/sprints/{{sprintId}}", "host": ["{{baseUrl}}"], "path": ["sprints", "{{sprintId}}"] }
          }
        }
      ]
    },
    {
