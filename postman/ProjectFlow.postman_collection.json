          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sprint 1 (revised)\",\n  \"goal\": \"Ship dashboard polish + my-tasks\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/sprints/{{sprintId}}", "host": ["{{baseUrl}}"], "path": ["sprints", "{{sprintId}}"] }
          }
        },
        {
          "name": "Start sprint",
          "request": {
            "method": "POST",
            "header": [],
