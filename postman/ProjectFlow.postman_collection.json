            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": \"{{projectId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/uploads/sign", "host": ["{{baseUrl}}"], "path": ["uploads", "sign"] }
          }
        }
      ]
    }
  ]
}
