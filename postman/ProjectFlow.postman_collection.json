            "url": { "raw": "{{baseUrl}}/components/{{componentId}}", "host": ["{{baseUrl}}"], "path": ["components", "{{componentId}}"] }
          }
        },
        {
          "name": "Delete component",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/components/{{componentId}}", "host": ["{{baseUrl}}"], "path": ["components", "{{componentId}}"] }
          }
        }
      ]
    },
    {
      "name": "Uploads",
      "item": [
        {
